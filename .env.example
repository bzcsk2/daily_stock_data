# Storage backend: csv, postgres, or both.
STORAGE_BACKEND=csv
DATA_DIR=./data

# Market calendar/timezone assumptions. Cron examples also use Asia/Shanghai.
MARKET_TIMEZONE=Asia/Shanghai

# Optional Python interpreter used by run_*.sh wrappers.
PYTHON_BIN=python3

# Batch wrapper settings.
DAILY_BATCH_SIZE=200
DAILY_MAX_WORKERS=1
DAILY_BATCH_TIMEOUT=1200
MIN5_BATCH_SIZE=100
MIN5_MAX_WORKERS=1
MIN5_BATCH_TIMEOUT=1800

# PostgreSQL settings. Used only when STORAGE_BACKEND=postgres or both.
MARKET_DB_HOST=localhost
MARKET_DB_PORT=5432
MARKET_DB_NAME=market
MARKET_DB_USER=postgres
MARKET_DB_PASSWORD=

# Optional data provider credentials.
TUSHARE_TOKEN=
TUSHARE_ENV_FILE=.env
TICKFLOW_API_KEY=
TICKFLOW_ENV_FILE=.env
TICKFLOW_BASE_URL=https://api.tickflow.org

# Optional pytdx host override. Format: host:port:alias,host:port:alias
# TDX_HOSTS=180.153.18.170:7709:shanghai-z1,202.108.253.130:7709:beijing-z1
