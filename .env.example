# Storage backend: csv, postgres, or both.
STORAGE_BACKEND=csv
DATA_DIR=./data

# Optional Python interpreter used by run_*.sh wrappers.
PYTHON_BIN=python3

# PostgreSQL settings. Used only when STORAGE_BACKEND=postgres or both.
MARKET_DB_HOST=localhost
MARKET_DB_PORT=5432
MARKET_DB_NAME=market
MARKET_DB_USER=postgres
MARKET_DB_PASSWORD=

# Optional data provider credentials.
TUSHARE_TOKEN=
TICKFLOW_API_KEY=
TICKFLOW_BASE_URL=https://api.tickflow.org
